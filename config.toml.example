[app]
listen_addr = ":8090"
base_url = "http://localhost:8090"

[database]
path = "broadwave.db"

[postmark]
server_token = "your-postmark-server-token"
message_stream = "outbound"

[subscribe]
default_redirect = "/"

[admin]
username = "admin"
# Generate with: htpasswd -nbBC 10 "" 'your-password' | cut -d: -f2
password_hash = ""
session_ttl = "24h"
